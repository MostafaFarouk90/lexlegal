# Supabase connection for the contact form (client-side, PUBLIC values).
# Copy this file to ".env.local" and fill in your project's values.
# Find them in: Supabase dashboard → Project Settings → API.
#
# The anon key is safe to expose in the browser — access is restricted by
# Row Level Security (see supabase/schema.sql). Do NOT put the service_role key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
